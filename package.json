{
  "name": "apple-notes-mcp",
  "version": "1.0.0",
  "description": "Comprehensive Apple Notes MCP server for local macOS note management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "apple-notes-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');const p='dist/index.js';if(fs.existsSync(p))fs.chmodSync(p,'755');\"",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apple-notes",
    "notes",
    "macos"
  ],
  "author": "Szakacs Media Company",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.7.3"
  }
}
